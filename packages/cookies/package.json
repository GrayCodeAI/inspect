{
  "name": "@inspect/cookies",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.35",
    "@inspect/observability": "workspace:*",
    "@inspect/shared": "workspace:*",
    "@playwright/browser-webkit": "^1.59.1",
    "default-browser": "^5.5.0",
    "effect": "4.0.0-beta.35",
    "get-port": "^7.1.0",
    "ini": "^6.0.0",
    "libsql": "^0.5.22"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
