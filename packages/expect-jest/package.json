{
  "name": "@inspect/expect-jest",
  "version": "0.2.0",
  "description": "Jest E2E adapter for Inspect - Browser automation testing with natural language",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "default": "./dist/setup.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "jest",
    "e2e",
    "testing",
    "browser",
    "automation",
    "inspect"
  ],
  "author": "Inspect Team",
  "license": "MIT",
  "dependencies": {
    "@inspect/browser": "workspace:*",
    "@inspect/agent": "workspace:*",
    "@inspect/core": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "jest": ">=29.0.0"
  }
}
