{
  "name": "@inspect/network",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "effect": "4.0.0-beta.35",
    "ws": "^8.18.0",
    "@inspect/observability": "workspace:*",
    "@inspect/shared": "workspace:*",
    "@playwright/browser-webkit": "^1.59.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.7.0"
  }
}
