{
  "name": "@inspect/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "effect": "4.0.0-beta.35",
    "@inspect/shared": "workspace:*",
    "@inspect/agent": "workspace:*",
    "@inspect/browser": "workspace:*",
    "@inspect/credentials": "workspace:*",
    "@inspect/quality": "workspace:*",
    "@inspect/observability": "workspace:*",
    "@inspect/visual": "workspace:*",
    "@inspect/devices": "workspace:*",
    "@inspect/git": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
