{
  "name": "@inspect/human-in-the-loop",
  "version": "0.1.0",
  "description": "Human approval checkpoints for autonomous test execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.35",
    "@playwright/browser-webkit": "^1.59.1",
    "effect": "4.0.0-beta.35"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
