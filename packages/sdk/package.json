{
  "name": "@inspect/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Inspect AI-powered browser testing SDK",
  "keywords": [
    "testing",
    "browser",
    "ai",
    "automation",
    "playwright",
    "e2e",
    "sdk"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inspect/shared": "workspace:*",
    "@inspect/browser": "workspace:*",
    "@inspect/agent": "workspace:*",
    "@inspect/core": "workspace:*",
    "@inspect/data": "workspace:*",
    "@inspect/quality": "workspace:*",
    "@inspect/observability": "workspace:*",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
