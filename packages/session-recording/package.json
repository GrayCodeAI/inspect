{
  "name": "@inspect/session-recording",
  "version": "0.1.0",
  "description": "Session recording and replay for browser tests using rrweb",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.35",
    "@playwright/browser-webkit": "^1.59.1",
    "@rrweb/types": "2.0.0-alpha.20",
    "effect": "4.0.0-beta.35",
    "rrweb": "2.0.0-alpha.20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
