{
  "name": "@inspect/session",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inspect/shared": "workspace:*",
    "@inspect/observability": "workspace:*",
    "@inspect/browser": "workspace:*",
    "effect": "4.0.0-beta.35",
    "@effect/platform-node": "4.0.0-beta.35",
    "rrweb": "^2.0.0-alpha.18",
    "@rrweb/types": "^2.0.0-alpha.18",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
