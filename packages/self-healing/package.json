    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.35",
    "@playwright/browser-webkit": "^1.59.1",
    "effect": "4.0.0-beta.35"
  },
  "devDependencies": {
    "@effect/vitest": "^4.0.0-beta.35",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
