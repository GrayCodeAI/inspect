{
  "name": "@inspect/self-healing",
  "version": "0.2.0",
  "description": "Self-healing selectors that adapt to DOM changes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
