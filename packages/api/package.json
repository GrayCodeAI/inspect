{
  "name": "@inspect/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "types": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middleware/rbac.js": {
      "types": "./dist/middleware/rbac.d.ts",
      "default": "./dist/middleware/rbac.js"
    }
  },
  "scripts": {
    "build": "tsc && cp src/openapi.json dist/",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inspect/enterprise": "workspace:*",
    "@inspect/observability": "workspace:*",
    "@inspect/shared": "workspace:*",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
