{
  "name": "@inspect/browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./src/*",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.35",
    "@inspect/observability": "workspace:*",
    "@inspect/shared": "workspace:*",
    "@medv/finder": "^4.0.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/browser-webkit": "^1.59.1",
    "@rrweb/types": "^2.0.0-alpha.18",
    "effect": "4.0.0-beta.35",
    "playwright": "^1.50.0",
    "rrweb": "^2.0.0-alpha.18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
