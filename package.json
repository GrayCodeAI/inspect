{
  "name": "inspect",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Powered Browser Testing Platform",
  "author": "Lakshman Patel",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/nichochar/inspect.git"
  },
  "homepage": "https://github.com/nichochar/inspect",
  "bugs": "https://github.com/nichochar/inspect/issues",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint packages/ apps/",
    "lint:fix": "eslint packages/ apps/ --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "inspect": "node apps/cli/dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
