{
  "name": "@inspect/inspect-recorder",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension for recording browser interactions as Inspect test scripts",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "@types/chrome": "^0.0.287"
  }
}
