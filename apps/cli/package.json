{
  "name": "@inspect/cli",
  "version": "0.1.0",
  "description": "AI-Powered Browser Testing CLI",
  "type": "module",
  "keywords": [
    "testing",
    "browser",
    "ai",
    "playwright",
    "cli",
    "accessibility",
    "visual-regression"
  ],
  "author": "Lakshman Patel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GrayCodeAI/inspect.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/GrayCodeAI/inspect",
  "bugs": "https://github.com/GrayCodeAI/inspect/issues",
  "bin": {
    "inspect": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inspect/agent": "workspace:*",
    "@inspect/api": "workspace:*",
    "@inspect/browser": "workspace:*",
    "@inspect/core": "workspace:*",
    "@inspect/credentials": "workspace:*",
    "@inspect/data": "workspace:*",
    "@inspect/enterprise": "workspace:*",
    "@inspect/network": "workspace:*",
    "@inspect/observability": "workspace:*",
    "@inspect/quality": "workspace:*",
    "@inspect/reporter": "workspace:*",
    "@inspect/shared": "workspace:*",
    "@inspect/visual": "workspace:*",
    "@inspect/workflow": "workspace:*",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "playwright": "^1.50.0",
    "typescript": "^5.7.0"
  }
}
