# =============================================================================
# Inspect - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# LLM API Keys (at least one required)
# ---------------------------------------------------------------------------

# Anthropic Claude (recommended primary)
ANTHROPIC_API_KEY=

# OpenAI GPT-4o / o3
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# DeepSeek R1 / V3
DEEPSEEK_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Groq (Llama models)
GROQ_API_KEY=

# Together AI
TOGETHER_API_KEY=

# Fireworks AI
FIREWORKS_API_KEY=

# OpenRouter (multi-model proxy)
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Inspect Configuration
# ---------------------------------------------------------------------------

# Default LLM model (e.g., claude-sonnet-4-20250514, gpt-4o, gemini-2.5-pro)
INSPECT_MODEL=claude-sonnet-4-20250514

# Agent interaction mode: dom, hybrid, or cua (computer use agent)
INSPECT_MODE=hybrid

# Run browser in headless mode (true/false)
INSPECT_HEADLESS=true

# Default base URL for tests
INSPECT_BASE_URL=

# Enable telemetry / OpenTelemetry export (true/false)
INSPECT_TELEMETRY=false

# Log level: debug, info, warn, error
INSPECT_LOG_LEVEL=info

# Path to inspect config file
INSPECT_CONFIG=

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------

# PostgreSQL connection string (for persistent storage)
DATABASE_URL=

# Redis connection string (for caching and queues)
REDIS_URL=

# Running inside Docker (auto-set by Dockerfile)
# IN_DOCKER=true

# ---------------------------------------------------------------------------
# Credential Providers
# ---------------------------------------------------------------------------

# Bitwarden Secrets Manager
BITWARDEN_API_KEY=
BITWARDEN_ORGANIZATION_ID=

# 1Password Connect
ONEPASSWORD_TOKEN=
ONEPASSWORD_CONNECT_HOST=

# Azure Key Vault
AZURE_KEY_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Cloud Browser Providers
# ---------------------------------------------------------------------------

# Browserbase (cloud browser sessions)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Security Scanning (optional)
# ---------------------------------------------------------------------------

# OWASP ZAP API
ZAP_API_URL=http://localhost:8080
ZAP_API_KEY=

# Nuclei binary path (default: nuclei in PATH)
NUCLEI_BINARY_PATH=

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------

# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=

# OpenTelemetry service name
OTEL_SERVICE_NAME=inspect

# Sentry DSN for error reporting
SENTRY_DSN=

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------

# API server port
PORT=3000

# API server host
HOST=0.0.0.0

# API authentication token
API_AUTH_TOKEN=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Webhooks & Notifications
# ---------------------------------------------------------------------------

# Slack webhook URL for test notifications
SLACK_WEBHOOK_URL=

# Discord webhook URL
DISCORD_WEBHOOK_URL=

# Generic webhook URL for test results
WEBHOOK_URL=

# Webhook secret for signature verification
WEBHOOK_SECRET=
